{
    "name": "@badisi/latest-version",
    "version": "8.0.6",
    "description": "Get latest versions of packages",
    "homepage": "https://github.com/Badisi/latest-version",
    "license": "MIT",
    "author": {
        "name": "Badisi"
    },
    "type": "module",
    "main": "./index.cjs",
    "module": "./index.mjs",
    "types": "./index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.mts",
                "default": "./index.mjs"
            },
            "require": {
                "types": "./index.d.cts",
                "default": "./index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "latest-version": "bin/latest-version",
        "lv": "bin/latest-version"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Badisi/latest-version"
    },
    "keywords": [
        "npm",
        "check",
        "updates",
        "latest",
        "current",
        "next",
        "version",
        "pkg",
        "package",
        "package-json",
        "dependencies",
        "module"
    ],
    "scripts": {
        "ncu": "npx npm-check-updates -i --format=group --packageFile '{,projects/**/}package.json' --no-deprecated",
        "start": "tsx src/cli.ts",
        "lint": "eslint .",
        "test": "vitest run",
        "test:ci": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc",
        "build": "tsc && tsdown",
        "release": "npm publish ./dist --access public"
    },
    "engines": {
        "node": ">= 20.12.0"
    },
    "dependencies": {
        "enquirer": "^2.4.1",
        "global-dirs": "3.0.1",
        "ora": "^9.4.0",
        "package-json": "^10.0.1",
        "registry-auth-token": "^5.1.1",
        "semver": "^7.8.0"
    },
    "devDependencies": {
        "@hug/eslint-config": "^25.0.1",
        "@types/node": "^22.0.0",
        "@types/registry-auth-token": "^4.2.4",
        "@types/semver": "^7.7.1",
        "tsdown": "^0.22.2",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0",
        "vitest": "^3.0.0"
    }
}
