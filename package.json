{
    "name": "@badisi/latest-version",
    "version": "9.0.0",
    "description": "Get latest versions of packages",
    "homepage": "https://github.com/Badisi/latest-version",
    "license": "MIT",
    "author": {
        "name": "Badisi"
    },
    "type": "module",
    "main": "./index.cjs",
    "module": "./index.mjs",
    "types": "./index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.mts",
                "default": "./index.mjs"
            },
            "require": {
                "types": "./index.d.cts",
                "default": "./index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Badisi/latest-version.git"
    },
    "keywords": [
        "npm",
        "check",
        "updates",
        "latest",
        "current",
        "next",
        "outdated",
        "version",
        "pkg",
        "package",
        "package-json",
        "dependencies",
        "module"
    ],
    "scripts": {
        "check-updates": "npx @badisi/check-updates -i",
        "lint": "eslint .",
        "test": "vitest",
        "test:ci": "vitest run",
        "typecheck": "tsc --noEmit",
        "build": "tsc && tsdown",
        "release": "npm publish ./dist --access public"
    },
    "engines": {
        "node": ">= 20.12.0"
    },
    "dependencies": {
        "global-dirs": "^3.0.1",
        "registry-auth-token": "^5.1.1",
        "semver": "^7.8.5"
    },
    "devDependencies": {
        "@hug/eslint-config": "^26.0.0",
        "@types/node": "^26.1.1",
        "@types/registry-auth-token": "^4.2.4",
        "@types/semver": "^7.7.1",
        "tsdown": "^0.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10"
    },
    "allowScripts": {
        "@hug/eslint-config@26.0.0": true,
        "fsevents@2.3.3": true
    }
}
